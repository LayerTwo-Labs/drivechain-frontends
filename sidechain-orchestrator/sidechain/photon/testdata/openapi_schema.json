  "paths": {
    "balance": {
      "post": {
        "description": "Get balance in sats",
        "operationId": "balance",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "total_sats",
                    "available_sats"
                  ],
                  "properties": {
                    "available_sats": {
                      "type": "integer",
                      "format": "u-int64",
                      "minimum": 0
                    },
                    "total_sats": {
                      "type": "integer",
                      "format": "u-int64",
                      "minimum": 0
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
